# Copy this to .env.local and fill in your values.
# Never commit real service-role keys, payment secrets, or email API keys.

# Supabase dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Razorpay dashboard -> Settings -> API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Get from resend.com after signup
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=R-R-Organic <orders@yourdomain.com>
CONTACT_TO_EMAIL=you@example.com

# Your site URL. Use http://localhost:3000 for local dev.
# Use your Amplify URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
